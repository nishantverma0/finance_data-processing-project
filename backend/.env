# ── Finance Dashboard – Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Django
SECRET_KEY=your-very-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Leave blank to use SQLite (default, great for local dev)
# PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=

# CORS – set to False and list origins explicitly in production
# CORS_ALLOW_ALL_ORIGINS is derived from DEBUG in settings.py
